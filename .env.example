# ===== Neon Postgres =====
# Lấy từ Neon dashboard: Project -> Connection Details -> Connection string (chọn "Pooled connection").
# Ví dụ:
# DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL=

# ===== Bảo mật phiên đăng nhập =====
# Chuỗi bí mật để ký token đăng nhập (JWT). Tạo chuỗi ngẫu nhiên >= 32 ký tự.
# Có thể tạo bằng: openssl rand -base64 32
AUTH_SECRET=
